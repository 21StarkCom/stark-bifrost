{
  "schemaVersion": 1,
  "bundle": {
    "name": "stark-gh",
    "version": "0.1.0",
    "description": "GitHub workflow commands + MCP for stark.",
    "category": "productivity",
    "tags": [
      "github",
      "pr",
      "workflow"
    ],
    "owner": "Evinced",
    "maturity": "beta",
    "homepage": "https://github.com/GetEvinced/stark-marketplace/tree/main/catalog/stark-gh"
  },
  "artifacts": [
    {
      "name": "pr-open",
      "type": "command",
      "description": "Open or update a PR with Codex-drafted prose.",
      "version": "0.1.0",
      "runtimes": [
        "claude",
        "codex",
        "gemini"
      ],
      "support": {
        "claude": "native",
        "codex": "native",
        "gemini": "native"
      },
      "requires": [],
      "diverged": false,
      "outputs": {
        "claude": [
          {
            "path": "commands/pr-open.md",
            "kind": "file",
            "emulated": false
          }
        ],
        "codex": [
          {
            "path": ".agents/skills/pr-open/SKILL.md",
            "kind": "file",
            "emulated": false
          }
        ],
        "gemini": [
          {
            "path": ".gemini/commands/pr-open.toml",
            "kind": "file",
            "emulated": false
          }
        ]
      },
      "fidelityNotes": {}
    },
    {
      "name": "gh",
      "type": "mcp",
      "description": "GitHub MCP server.",
      "version": "0.1.0",
      "runtimes": [
        "claude",
        "codex",
        "gemini"
      ],
      "support": {
        "claude": "native",
        "codex": "native",
        "gemini": "native"
      },
      "requires": [],
      "diverged": false,
      "outputs": {
        "claude": [
          {
            "path": ".mcp.json",
            "kind": "mergeJSONKey",
            "key": "mcpServers.gh",
            "emulated": false
          }
        ],
        "codex": [
          {
            "path": "config.toml",
            "kind": "mergeTOMLKey",
            "key": "mcp_servers.gh",
            "emulated": false
          }
        ],
        "gemini": [
          {
            "path": "settings.json",
            "kind": "mergeJSONKey",
            "key": "mcpServers.gh",
            "emulated": false
          }
        ]
      },
      "fidelityNotes": {}
    }
  ]
}
