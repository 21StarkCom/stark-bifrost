{
  "schemaVersion": 1,
  "bundle": {
    "name": "stark-gh",
    "version": "0.1.3",
    "description": "GitHub workflow commands + MCP for stark.",
    "category": "productivity",
    "tags": [
      "github",
      "pr",
      "workflow"
    ],
    "owner": "Evinced",
    "maturity": "beta",
    "homepage": "https://github.com/21-Stark-AI/stark-marketplace/tree/main/catalog/stark-gh"
  },
  "artifacts": [
    {
      "name": "cleanup",
      "type": "command",
      "description": "Sweep the local + remote repo for merged-PR branches, stale tracking refs, worktree leftovers (including detached-HEAD review worktrees), merged-PR watcher state, stale stashes, and loose objects. Rebases the current branch onto upstream and applies linear-tree git config so the history stays sharp.",
      "version": "0.1.3",
      "runtimes": [
        "claude",
        "codex",
        "gemini"
      ],
      "support": {
        "claude": "native",
        "codex": "native",
        "gemini": "native"
      },
      "requires": [],
      "diverged": false,
      "outputs": {
        "claude": [
          {
            "path": "commands/cleanup.md",
            "kind": "file",
            "emulated": false
          }
        ],
        "codex": [
          {
            "path": ".agents/skills/cleanup/SKILL.md",
            "kind": "file",
            "emulated": false
          }
        ],
        "gemini": [
          {
            "path": ".gemini/commands/cleanup.toml",
            "kind": "file",
            "emulated": false
          }
        ]
      },
      "fidelityNotes": {}
    },
    {
      "name": "pr-merge",
      "type": "command",
      "description": "Rebase a PR, draft squash-commit prose + CHANGELOG bullet via Codex, force-push, and squash-merge once CI is green.",
      "version": "0.1.3",
      "runtimes": [
        "claude",
        "codex",
        "gemini"
      ],
      "support": {
        "claude": "native",
        "codex": "native",
        "gemini": "native"
      },
      "requires": [],
      "diverged": false,
      "outputs": {
        "claude": [
          {
            "path": "commands/pr-merge.md",
            "kind": "file",
            "emulated": false
          }
        ],
        "codex": [
          {
            "path": ".agents/skills/pr-merge/SKILL.md",
            "kind": "file",
            "emulated": false
          }
        ],
        "gemini": [
          {
            "path": ".gemini/commands/pr-merge.toml",
            "kind": "file",
            "emulated": false
          }
        ]
      },
      "fidelityNotes": {}
    },
    {
      "name": "pr-open",
      "type": "command",
      "description": "Open or update a PR with Codex-drafted prose, stage-all commit (default), push, and CI watcher.",
      "version": "0.1.3",
      "runtimes": [
        "claude",
        "codex",
        "gemini"
      ],
      "support": {
        "claude": "native",
        "codex": "native",
        "gemini": "native"
      },
      "requires": [],
      "diverged": false,
      "outputs": {
        "claude": [
          {
            "path": "commands/pr-open.md",
            "kind": "file",
            "emulated": false
          }
        ],
        "codex": [
          {
            "path": ".agents/skills/pr-open/SKILL.md",
            "kind": "file",
            "emulated": false
          }
        ],
        "gemini": [
          {
            "path": ".gemini/commands/pr-open.toml",
            "kind": "file",
            "emulated": false
          }
        ]
      },
      "fidelityNotes": {}
    },
    {
      "name": "gh",
      "type": "mcp",
      "description": "GitHub MCP server.",
      "version": "0.1.0",
      "runtimes": [
        "claude",
        "codex",
        "gemini"
      ],
      "support": {
        "claude": "native",
        "codex": "native",
        "gemini": "native"
      },
      "requires": [],
      "diverged": false,
      "outputs": {
        "claude": [
          {
            "path": ".mcp.json",
            "kind": "mergeJSONKey",
            "key": "mcpServers.gh",
            "emulated": false
          }
        ],
        "codex": [
          {
            "path": "config.toml",
            "kind": "mergeTOMLKey",
            "key": "mcp_servers.gh",
            "emulated": false
          }
        ],
        "gemini": [
          {
            "path": "settings.json",
            "kind": "mergeJSONKey",
            "key": "mcpServers.gh",
            "emulated": false
          }
        ]
      },
      "fidelityNotes": {}
    }
  ]
}
